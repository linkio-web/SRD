4 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"\" aria-hidden=\"true\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a></div></div></section><section class=\"relative bg-cream overflow-hidden\"><svg aria-hidden=\"true\" viewBox=\"0 0 1440 80\" preserveAspectRatio=\"none\" class=\"absolute top-0 left-0 w-full\" style=\"height:var(--slant-h)\" xmlns=\"http://www.w3.org/2000/svg\"><polygon points=\"0,0 1440,0 1440,80\" fill=\"#46184E\"></polygon></svg><div class=\"container-main pt-32 sm:pt-40 pb-24 sm:pb-32\"><div class=\"grid grid-cols-1 lg:grid-cols-[1fr_288px] gap-16 items-start\"><div><h2 class=\"font-display text-2xl sm:text-3xl font-light text-navy mb-10 leading-tight\">What we handle</h2><div><div class=\"flex items-start gap-6 py-7 border-b border-primary-100/40 last:border-b-0\"><span class=\"font-body text-[10px] font-semibold tracking-[0.14em] text-champagne w-5 shrink-0 mt-0.5 select-none\" aria-hidden=\"true\">01</span><div><p class=\"font-body font-semibold text-navy text-base leading-snug\">Invoicing and payment management</p></div></div><div class=\"flex items-start gap-6 py-7 border-b border-primary-100/40 last:border-b-0\"><span class=\"font-body text-[10px] font-semibold tracking-[0.14em] text-champagne w-5 shrink-0 mt-0.5 select-none\" aria-hidden=\"true\">02</span><div><p class=\"font-body font-semibold text-navy text-base leading-snug\">Debtor and creditor monitoring</p></div></div><div class=\"flex items-start gap-6 py-7 border-b border-primary-100/40 last:border-b-0\"><span class=\"font-body text-[10px] font-semibold tracking-[0.14em] text-champagne w-5 shrink-0 mt-0.5 select-none\" aria-hidden=\"true\">03</span><div><p class=\"font-body font-semibold text-navy text-base leading-snug\">Company domiciliation and mail forwarding</p></div></div></div><div class=\"flex items-center gap-4 my-12\" aria-hidden=\"tr