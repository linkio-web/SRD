\",\"children\":\"Ils nous font confiance\"}],[\"$\",\"h2\",null,{\"className\":\"font-display font-light text-3xl sm:text-4xl lg:text-5xl leading-[1.15] tracking-[-0.01em] text-navy\",\"children\":[\"Ce que disent\",\" \",[\"$\",\"span\",null,{\"className\":\"italic font-light text-champagne\",\"children\":\"nos clients\"}]]}]]}],[\"$\",\"figure\",null,{\"className\":\"text-center max-w-3xl mx-auto\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-display block leading-[0.75] text-gold/[0.13] select-none pointer-events-none -mb-5\",\"style\":{\"fontSize\":\"clamp(5rem, 12vw, 8rem)\"},\"aria-hidden\":\"true\",\"children\":\"“\"}],[\"$\",\"blockquote\",null,{\"children\":[\"$\",\"p\",null,{\"className\":\"font-display font-light italic text-xl sm:text-[1.6rem] text-ink/80 leading-[1.62]\",\"children\":\"SRD Partners a transformé notre approche financière. Grâce à leur expertise pointue, nous avons optimisé notre charge fiscale de manière significative tout en gagnant une visibilité accrue sur nos performances.\"}]}],[\"$\",\"figcaption\",null,{\"className\":\"mt-8 flex flex-col items-center gap-1.5\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-px bg-gold/45 mb-3\",\"aria-hidden\":\"true\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-sm font-semibold text-navy\",\"children\":\"M. Durand\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-xs text-muted\",\"children\":\"Directeur général, PME industrielle\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-5 my-14 sm:my-16\",\"aria-hidden\":\"true\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex-1 h-px bg-black/[0.07]\"}],[\"$\",\"div\",null,{\"className\":\"w-1 h-1 rounded-full bg-gold/40\"}],[\"$\",\"div\",null,{\"className\":\"flex-1 h-px bg-black/[0.07]\"}]]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 sm:grid-cols-2 gap-10 lg:gap-16\",\"children\":[[\"$\",\"figure\",\"Mme Laurent\",{\"className\":\"flex flex-col gap-5\",\"children\":[[\"$\",\"svg\",null,{\"width\":20,\"height\":20,\"viewBox\":\"0 0 24 24\",\"fill\":\"currentColor\",\"stroke\":\"none\",\"strokeWidth\":1.5,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"text-gold/35\",\"aria-hidden\":true,\"children\":[\"$\",\"path\",null,{\"d\":\"M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z\"}]}],[\"$\",\"blockquote\",null,{\"children\":[\"$\",\"p\",null,{\"className\":\"font-display font-light italic text-base sm:text-lg text-ink/70 leading-[1.76]\",\"children\":\"Une équipe réactive, disponible et d'une rigueur exemplaire. Depuis que nous leur avons confié notre comptabilité, nous pouvons nous concentrer pleinement sur notre cœur de métier.\"}]}],[\"$\",\"figcaption\",null,{\"className\":\"flex items-center gap-3 pt-5 border-t border-black/[0.07]\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-9 h-9 rounded-full bg-navy text-white flex items-center justify-center font-body text-[10px] font-semibold tracking-[0.08em] shrink-0\",\"aria-hidden\":\"true\",\"children\":\"ML\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-body text-sm font-semibold text-navy leading-snug\",\"children\":\"Mme Laurent\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-xs text-muted mt-0.5\",\"children\":\"Gérante, Société de services\"}]]}]]}]]}],[\"$\",\"figure\",\"M. & Mme Favre\",{\"className\":\"flex flex-col gap-5\",\"children\":[[\"$\",\"svg\",null,{\"width\":20,\"height\":20,\"viewBox\":\"0 0 24 24\",\"fill\":\"currentColor\",\"stroke\":\"none\",\"strokeWidth\":1.5,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"text-gold/35\",\"aria-hidden\":true,\"children\":\"$L24\"}],\"$L25\",\"$L26\"]}]]}]]}]]}]\n1c:[\"$\",\"$L27\",null,{\"t\":{\"overline\":\"Notre approche\",\"titleMain\":\"Un accompagnement\",\"titleAccent\":\"structuré\",\"deliverablesLabel\":\"Livrables\",\"steps\":[{\"number\":\"01\",\"title\":\"Premier contact\",\"description\":\"Nous prenons le temps de comprendre votre situation, vos objectifs et vos contraintes. Un premier entretien sans engagement vous permet d'exposer vos besoins et de découvrir notre approche.\",\"deliverables\":[\"Diagnostic initial\",\"Proposition sur mesure\",\"Devis transparent\"]},{\"number\":\"02\",\"title\":\"Analyse & Stratégie\",\"description\":\"Nos experts analysent votre situation financière, fiscale et administrative en profondeur. Nous définissons ensemble la stratégie optimale pour atteindre vos objectifs dans les meilleures conditions.\",\"deliverables\":[\"Rapport d'analyse\",\"Plan d'action détaillé\",\"Calendrier d'exécution\"]},{\"number\":\"03\",\"title\":\"Mise en œuvre\",\"description\":\"Nous exécutons le plan d'action avec rigueur et dans les délais convenus. Vous bénéficiez d'un suivi régulier et d'une communication proactive à chaque étape clé de la mission.\",\"deliverables\":[\"Dossiers conformes\",\"Déclarations déposées\",\"Rapports intermédiaires\"]},{\"number\":\"04\",\"title\":\"Suivi continu\",\"description\":\"Notre engagement ne s'arrête pas à la mission initiale. Nous restons votre partenaire au quotidien, disponibles pour répondre à vos questions et anticiper les évolutions de votre situation.\",\"deliverables\":[\"Veille réglementaire\",\"Revues périodiques\",\"Conseil permanent\"]}]},\"slantFill\":\"#D2C9D6\"}]\n1d:[\"$\",\"$L28\",null,{\"t\":{\"overline\":\"Questions fréquentes\",\"titleMain\":\"Vos questions,\",\"titleAccent\":\"nos réponses\",\"subtitle\":\"Tout ce que vous devez savoir avant de nous confier votre dossier.\",\"items\":[{\"question\":\"Combien coûte une déclaration d'impôts ?\",\"answer\":\"Nos honoraires dépendent de la complexité de votre situation fiscale et du type de déclaration concernée (personne physique, société, succession). Nous établissons systématiquement un devis transparent avant toute mission. N'hésitez pas à nous contacter pour un entretien préliminaire sans engagement.\"},{\"question\":\"Quels documents dois-je fournir ?\",\"answer\":\"La liste varie selon votre profil, mais inclut généralement : certificats de salaire, relevés bancaires et de prévoyance, attestations d'assurance, titres de propriété et tout document relatif à vos revenus et déductions. Après un premier échange, nous vous communiquons une liste personnalisée et précise.\"},{\"question\":\"Combien de temps prend le traitement ?\",\"answer\":\"Pour une déclaration fiscale standard, comptez en moyenne 2 à 4 semaines après réception de l'ensemble des documents. Les dossiers plus complexes font l'objet d'un calendrier défini en amont avec vous. Nous vous informons à chaque étape clé du traitement.\"},{\"question\":\"Puis-je planifier un rendez-vous ?\",\"answer\":\"Absolument. Nous proposons des entretiens en cabinet à Genève ou Lausanne, ainsi que des consultations en visioconférence. Le premier entretien est sans engagement et vous permet d'exposer votre situation en toute sérénité. Contactez-nous via notre formulaire ou par téléphone pour convenir d'un créneau.\"},{\"question\":\"Est-ce confidentiel ?\",\"answer\":\"La confidentialité est un principe fondamental de notre profession. Toutes les informations que vous nous confiez sont protégées par le secret professionnel et traitées avec la plus grande discrétion. Vos données ne sont jamais partagées avec des tiers sans votre accord explicite.\"}]}}]\n1e:[\"$\",\"$L29\",null,{\"bg\":\"stone\",\"slant\":\"left\",\"slantFill\":\"#F8F9FC\",\"t\":{\"overline\":\"Contactez-nous\",\"title\":\"Parlons de votre projet\",\"subtitle\":\"Remplissez le formulaire ci-dessous et nous vous répondrons dans les 24 heures ouvrables.\",\"trustLine\":\"Réponse sous 24h ouvrables · Confidentialité garantie\",\"fullName\":\"Nom et prénom *\",\"company\":\"Société\",\"email\":\"Adresse e-mail *\",\"phone\":\"Téléphone\",\"subject\":\"Sujet *\",\"subjectDefault\":\"Sélectionner un sujet…\",\"message\":\"Message *\",\"required\":\"* Champs obligatoires\",\"submit\":\"Envoyer le message\",\"submitting\":\"Envoi en cours…\",\"successTitle\":\"Message envoyé !\",\"successMsg\":\"Merci pour votre message. Notre équipe vous contactera très prochainement.\",\"sendAnother\":\"Envoyer un autre message\",\"errorTitle\":\"Envoi échoué\",\"errorMsg\":\"Une erreur est survenue. Veuillez réessayer ou nous contacter directement par téléphone.\",\"retry\":\"Réessayer\",\"subjects\":{\"accounting\":\"Comptabilité & Fiscalité\",\"consulting\":\"Conseil en gestion\",\"audit\":\"Audit & Révision\",\"patrimony\":\"Planification patrimoniale\",\"creation\":\"Création d'entreprise\",\"hr\":\"RH & Paie\",\"other\":\"Autre\"},\"errors\":{\"name\":\"Votre nom est requis.\",\"email\":\"Votre adresse e-mail est requise.\",\"emailInvalid\":\"Adresse e-mail invalide.\",\"subject\":\"Le sujet est requis.\",\"message\":\"Votre message est requis.\"},\"placeholders\":{\"name\":\"Sophie Dupont\",\"company\":\"Ma Société Sàrl\",\"email\":\"sophie@exemple.ch\",\"phone\":\"+41 79 000 00 00\",\"message\":\"Décrivez brièvement votre besoin…\"}}}]\n1f:[\"$\",\"footer\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"h-[3px] bg-gold\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",null,{\"className\":\"bg-navy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container-main pt-14 pb-10 lg:pt-16 lg:pb-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"md:col-span-2 lg:col-span-1 flex flex-col gap-5\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/fr\",\"className\":\"inline-flex self-start rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold\",\"aria-label\":\"SRD Partners Sàrl\",\"children\":[\"$\",\"div\",null,{\"className\":\"bg-white 