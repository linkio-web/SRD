d-cols-1 sm:grid-cols-[2rem_18rem_1fr] gap-x-10 lg:gap-x-16 gap-y-2 py-10 sm:py-12 border-t border-black/[0.06] items-start sm:items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-body text-[10px] tracking-[0.22em] text-champagne font-medium select-none\",\"aria-hidden\":\"true\",\"children\":[\"0\",3]}],[\"$\",\"h3\",null,{\"className\":\"font-display text-xl sm:text-2xl font-light text-navy leading-tight\",\"children\":\"Confidentialité absolue\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-sm text-muted leading-[1.80] col-start-1 sm:col-start-auto\",\"children\":\"La discrétion est au cœur de notre métier. Vos données et vos projets sont traités avec le plus grand soin et dans le strict respect de la confidentialité professionnelle.\"}]]}]\n19:[\"$\",\"div\",null,{\"className\":\"border-t border-black/[0.06]\"}]\n1a:[\"$\",\"section\",null,{\"className\":\"bg-navy relative overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"className\":\"navy-grain absolute inset-0 pointer-events-none opacity-[0.04]\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",null,{\"className\":\"relative z-10 container-main py-24 sm:py-32\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-end justify-between pb-10 sm:pb-14 border-b border-white/[0.07]\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"span\",null,{\"className\":\"section-label text-champagne/70\",\"children\":\"Ce que nous faisons\"}],[\"$\",\"h2\",null,{\"className\":\"font-display text-3xl sm:text-4xl lg:text-5xl font-light text-white mt-1 leading-tight\",\"children\":[\"Nos domaines\",\" \",[\"$\",\"span\",null,{\"className\":\"italic text-champagne\",\"children\":\"d'expertise\"}]]}]]}],[\"$\",\"$L13\",null,{\"href\":\"/fr/services\",\"className\":\"hidden sm:flex items-center gap-2 font-body text-xs text-white/30 hover:text-champagne transition-colors duration-200 shrink-0 ml-8 pb-1\",\"children\":[\"Voir tous nos services\",[\"$\",\"svg\",null,{\"width\":13,\"height\":13,