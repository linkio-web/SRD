,[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid grid-cols-1 sm:grid-cols-2 gap-10 lg:gap-16\\\",\\\"children\\\":[[\\\"$\\\",\\\"figure\\\",\\\"Mme Laurent\\\",{\\\"className\\\":\\\"flex flex-col gap-5\\\",\\\"children\\\":[[\\\"$\\\",\\\"svg\\\",null,{\\\"width\\\":20,\\\"height\\\":20,\\\"viewBox\\\":\\\"0 0 24 24\\\",\\\"fill\\\":\\\"currentColor\\\",\\\"stroke\\\":\\\"none\\\",\\\"strokeWidth\\\":1.5,\\\"strokeLinecap\\\":\\\"round\\\",\\\"strokeLinejoin\\\":\\\"round\\\",\\\"className\\\":\\\"text-gold/35\\\",\\\"aria-hidden\\\":true,\\\"children\\\":[\\\"$\\\",\\\"path\\\",null,{\\\"d\\\":\\\"M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z\\\"}]}],[\\\"$\\\",\\\"blockquote\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-display font-light italic text-base sm:text-lg text-ink/70 leading-[1.76]\\\",\\\"children\\\":\\\"Une équipe réactive, disponible et d'une rigueur exemplaire. Depuis que nous leur avons confié notre comptabilité, nous pouvons nous concentrer pleinement sur notre cœur de métier.\\\"}]}],[\\\"$\\\",\\\"figcaption\\\",null,{\\\"className\\\":\\\"flex items-center gap-3 pt-5 border-t border-black/[0.07]\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-9 h-9 rounded-full bg-navy text-white flex items-center justify-center font-body text-[10px] font-semibold tracking-[0.08em] shrink-0\\\",\\\"aria-hidden\\\":\\\"true\\\",\\\"children\\\":\\\"ML\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-body text-sm font-semibold text-navy leading-snug\\\",\\\"children\\\":\\\"Mme Laurent\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-body text-xs text-muted mt-0.5\\\",\\\"children\\\":\\\"Gérante, Société de