number\\\":\\\"04\\\",\\\"title\\\":\\\"Suivi continu\\\",\\\"description\\\":\\\"Notre engagement ne s'arrête pas à la mission initiale. Nous restons votre partenaire au quotidien, disponibles pour répondre à vos questions et anticiper les évolutions de votre situation.\\\",\\\"deliverables\\\":[\\\"Veille réglementaire\\\",\\\"Revues périodiques\\\",\\\"Conseil permanent\\\"]}]},\\\"slantFill\\\":\\\"#D2C9D6\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"1d:[\\\"$\\\",\\\"$L28\\\",null,{\\\"t\\\":{\\\"overline\\\":\\\"Questions fréquentes\\\",\\\"titleMain\\\":\\\"Vos questions,\\\",\\\"titleAccent\\\":\\\"nos réponses\\\",\\\"subtitle\\\":\\\"Tout ce que vous devez savoir avant de nous confier votre dossier.\\\",\\\"items\\\":[{\\\"question\\\":\\\"Combien coûte une déclaration d'impôts ?\\\",\\\"answer\\\":\\\"Nos honoraires dépendent de la complexité de votre situation fiscale et du type de déclaration concernée (personne physique, société, succession). Nous établissons systématiquement un devis transparent avant toute mission. N'hésitez pas à nous contacter pour un entretien préliminaire sans engagement.\\\"},{\\\"question\\\":\\\"Quels documents dois-je fournir ?\\\",\\\"answer\\\":\\\"La liste varie selon votre profil, mais inclut généralement : certificats de salaire, relevés bancaires et de prévoyance, attestations d'assurance, titres de propriété et tout document relatif à vos revenus et déductions. Après un premier échange, nous vous communiquons une liste personnalisée et précise.\\\"},{\\\"question\\\":\\\"Combien de temps prend le traitement ?\\\",\\\"answer\\\":\\\"Pour une déclaration fiscale standard, comptez en moyenne 2 à 4 semaines après réception de l'ensemble des documents. Les dossiers plus complexes font l'objet d'un calendrier défini en amont avec vous. Nous vous informons à chaque étape clé du traitement.\\\"},{\\\"question\\\":\\\"Puis-je planifier un rendez-vous ?\\\",\\\"answer\\\":\\\"Absolument. Nous proposons des entretiens en cabinet à Genève ou Lausanne, ainsi que des consultations en visioconférence. Le premier entretien est sans engagement et vous permet d'exposer votre situation en toute sérénité. Contactez-nous via notre formulaire ou par téléphone pour convenir d'un créneau.\\\"},{\\\"question\\\":\\\"Est-ce confidentiel ?\\\",\\\"answer\\\":\\\"La confidentialité est un principe fondamental de notre profession. Toutes les informations que vous nous confiez sont protégées par le secret professionnel et traitées avec la plus grande discrétion. Vos données ne sont jamais partagées avec des tiers sans votre accord explicite.\\\"}]}}]\\n\"])</script><script>self.__next_f.push([1,\"1e:[\\\"$\\\",\\\"$L29\\\",null,{\\\"bg\\\":\\\"stone\\\",\\\"slant\\\":\\\"left\\\",\\\"slantFill\\\":\\\"#F8F9FC\\\",\\\"t\\\":{\\\"overline\\\":\\\"Contactez-nous\\\",\\\"title\\\":\\\"Parlons de votre projet\\\",\\\"subtitle\\\":\\\"Remplissez le formulaire ci-dessous et nous vous répondrons dans les 24 heures ouvrables.\\\",\\\"trustLine\\\":\\\"Réponse sous 24h ouvrables · Confidentialité garantie\\\",\\\"fullName\\\":\\\"Nom et prénom *\\\",\\\"company\\\":\\\"Société\\\",\\\"email\\\":\\\"Adresse e-mail *\\\",\\\"phone\\\":\\\"Téléphone\\\",\\\"subject\\\":\\\"Sujet *\\\",\\\"subjectDefault\\\":\\\"Sélectionner un sujet…\\\",\\\"message\\\":\\\"Message *\\\",\\\"required\\\":\\\"* Champs obligatoires\\\",\\\"submit\\\":\\\"Envoyer le message\\\",\\\"submitting\\\":\\\"Envoi en cours…\\\",\\\"successTitle\\\":\\\"Message envoyé !\\\",\\\"successMsg\\\":\\\"Merci pour votre message. Notre équipe vous contactera très prochainement.\\\",\\\"sendAnother\\\":\\\"Envoyer un autre message\\\",\\\"errorTitle\\\":\\\"Envoi échoué\\\",\\\"errorMsg\\\":\\\"Une erreur est survenue. Veuillez réessayer ou nous contacter directement par téléphone.\\\",\\\"retry\\\":\\\"Réessayer\\\",\\\"subjects\\\":{\\\"accounting\\\":\\\"Comptabilité \\u0026 Fiscalité\\\",\\\"consulting\\\":\\\"Conseil en gestion\\\",\\\"audit\\\":