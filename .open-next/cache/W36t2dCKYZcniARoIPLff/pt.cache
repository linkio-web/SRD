:text-2xl font-light text-navy leading-tight\",\"children\":\"Experiência reconhecida\"}]\n16:[\"$\",\"p\",null,{\"className\":\"font-body text-sm text-muted leading-[1.80] col-start-1 sm:col-start-auto\",\"children\":\"Mais de 15 anos de experiência ao serviço de PME na Suíça francófona. Conselhos comprovados, visão estratégica apurada e profundo domínio do enquadramento legal suíço.\"}]\n17:[\"$\",\"div\",\"Abordagem personalizada\",{\"className\":\"grid grid-cols-1 sm:grid-cols-[2rem_18rem_1fr] gap-x-10 lg:gap-x-16 gap-y-2 py-10 sm:py-12 border-t border-black/[0.06] items-start sm:items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-body text-[10px] tracking-[0.22em] text-champagne font-medium select-none\",\"aria-hidden\":\"true\",\"children\":[\"0\",2]}],[\"$\",\"h3\",null,{\"className\":\"font-display text-xl sm:text-2xl font-light text-navy leading-tight\",\"children\":\"Abordagem personalizada\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-sm text-muted leading-[1.80] col-start-1 sm:col-start-auto\",\"children\":\"Cada cliente é único. Construímos uma relação de confiança duradoura e adaptamos as nossas soluções aos seus desafios específicos, independentemente da dimensão da sua estrutura.\"}]]}]\n18:[\"$\",\"div\",\"Confidencialidade absoluta\",{\"className\":\"grid grid-cols-1 sm:grid-cols-[2rem_18rem_1fr] gap-x-10 lg:gap-x-16 gap-y-2 py-10 sm:py-12 border-t border-black/[0.06] items-start sm:items-center\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-body text-[10px] tracking-[0.22em] text-champagne font-medium select-none\",\"aria-hidden\":\"true\",\"children\":[\"0\",3]}],[\"$\",\"h3\",null,{\"className\":\"font-display text-xl sm:text-2xl font-light text-navy leading-tight\",\"children\":\"Confidencialidade absoluta\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-sm text-muted leading-[1.80] col-start-1 sm:col-start-auto\",\"children\":\"A discrição está no centro do nosso trabalho. Os seus dados e projetos s