\",null,{\"children\":[\"$\",\"p\",null,{\"className\":\"font-display font-light italic text-xl sm:text-[1.6rem] text-ink/80 leading-[1.62]\",\"children\":\"A SRD Partners transformou a nossa abordagem financeira. Graças à sua expertise apurada, otimizámos significativamente a nossa carga fiscal e ganhamos maior visibilidade sobre o nosso desempenho.\"}]}],[\"$\",\"figcaption\",null,{\"className\":\"mt-8 flex flex-col items-center gap-1.5\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-8 h-px bg-gold/45 mb-3\",\"aria-hidden\":\"true\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-sm font-semibold text-navy\",\"children\":\"Sr. Durand\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-xs text-muted\",\"children\":\"Diretor geral, PME industrial\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-5 my-14 sm:my-16\",\"aria-hidden\":\"true\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex-1 h-px bg-black/[0.07]\"}],[\"$\",\"div\",null,{\"className\":\"w-1 h-1 rounded-full bg-gold/40\"}],[\"$\",\"div\",null,{\"className\":\"flex-1 h-px bg-black/[0.07]\"}]]}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 sm:grid-cols-2 gap-10 lg:gap-16\",\"children\":[[\"$\",\"figure\",\"Sra. Laurent\",{\"className\":\"flex flex-col gap-5\",\"children\":[[\"$\",\"svg\",null,{\"width\":20,\"height\":20,\"viewBox\":\"0 0 24 24\",\"fill\":\"currentColor\",\"stroke\":\"none\",\"strokeWidth\":1.5,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"text-gold/35\",\"aria-hidden\":true,\"children\":[\"$\",\"path\",null,{\"d\":\"M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z\"}]}],[\"$\",\"blockquote\",null,{\"children\":[\"$\",\"p\",null,{\"className\":\"font-display font-light italic text-base sm:text-lg text-ink/70 leading-[1.76]\",\"children\":\"Uma equipa reativa, disponível e de rigor exemplar. Desde que lhes confiamos a nossa contabilidade, podemos concentrar-nos totalmente no nosso negócio principal.\"}]}],[\"$\",\"figcaption\",null,{\"className\":\"flex items-center gap-3 pt-5 border-t border-black/[0.07]\",\"children\":[[\"$\",\"div\",null,{\"className\":\"w-9 h-9 rounded-full bg-navy text-white flex items-center justify-center font-body text-[10px] font-semibold tracking-[0.08em] shrink-0\",\"aria-hidden\":\"true\",\"children\":\"ML\"}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-body text-sm font-semibold text-navy leading-snug\",\"children\":\"Sra. Laurent\"}],[\"$\",\"p\",null,{\"className\":\"font-body text-xs text-muted mt-0.5\",\"children\":\"Gerente, empresa de serviços\"}]]}]]}]]}],[\"$\",\"figure\",\"Sr. & Sra. Favre\",{\"className\":\"flex flex-col gap-5\",\"children\":[[\"$\",\"svg\",null,{\"width\":20,\"height\":20,\"viewBox\":\"0 0 24 24\",\"fill\":\"currentColor\",\"stroke\":\"none\",\"strokeWidth\":1.5,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"className\":\"text-gold/35\",\"aria-hidden\":true,\"children\":\"$L24\"}],\"$L25\",\"$L26\"]}]]}]]}]]}]\n1c:[\"$\",\"$L27\",null,{\"t\":{\"overline\":\"A nossa abordagem\",\"titleMain\":\"Um acompanhamento\",\"titleAccent\":\"estruturado\",\"deliverablesLabel\":\"Entregáveis\",\"steps\":[{\"number\":\"01\",\"title\":\"Primeiro contacto\",\"description\":\"Dedicamos tempo a compreender a sua situação, objetivos e limitações. Uma primeira reunião sem compromisso permite-lhe expor as suas necessidades e descobrir a nossa abordagem.\",\"deliverables\":[\"Diagnóstico inicial\",\"Proposta personalizada\",\"Orçamento transparente\"]},{\"number\":\"02\",\"title\":\"Análise & Estratégia\",\"description\":\"Os nossos especialistas analisam em profundidade a sua situação financeira, fiscal e administrativa. Definimos juntos a estratégia ideal para atingir os seus objetivos nas melhores condições.\",\"deliverables\":[\"Relatório de análise\",\"Plano de ação detalhado\",\"Calendário de execução\"]},{\"number\":\"03\",\"title\":\"Implementação\",\"description\":\"Executamos o plano de ação com rigor e nos prazos acordados. Beneficia de um acompanhamento regular e de uma comunicação proativa em cada etapa-chave da missão.\",\"deliverables\":[\"Dossiers conformes\",\"Declarações entregues\",\"Relatórios intercalares\"]},{\"number\":\"04\",\"title\":\"Acompanhamento contínuo\",\"description\":\"O nosso compromisso não termina com a missão inicial. Continuamos a ser o seu parceiro diário, disponíveis para responder às suas questões e antecipar as evoluções da sua situação.\",\"deliverables\":[\"Monitorização regulatória\",\"Revisões periódicas\",\"Consultoria permanente\"]}]},\"slantFill\":\"#D2C9D6\"}]\n1d:[\"$\",\"$L28\",null,{\"t\":{\"overline\":\"Perguntas frequentes\",\"titleMain\":\"As suas perguntas,\",\"titleAccent\":\"as nossas respostas\",\"subtitle\":\"Tudo o que precisa de saber antes de nos confiar o seu dossier.\",\"items\":[{\"question\":\"Quanto custa uma declaração fiscal?\",\"answer\":\"Os nossos honorários dependem da complexidade da sua situação fiscal e do tipo de declaração (pessoa singular, empresa, sucessão). Estabelecemos sistematicamente um orçamento transparente antes de qualquer missão. Não hesite em contactar-nos para uma reunião preliminar sem compromisso.\"},{\"question\":\"Que documentos devo fornecer?\",\"answer\":\"A lista varia conforme o seu perfil, mas geralmente inclui: certificados de salário, extratos bancários e de previdência, atestados de seguro, títulos de propriedade e todos os documentos relativos aos seus rendimentos e deduções. Após um primeiro contacto, enviamos-lhe uma lista personalizada e precisa.\"},{\"question\":\"Quanto tempo demora o tratamento?\",\"answer\":\"Para uma declaração fiscal standard, conte em média 2 a 4 semanas após a receção de todos os documentos. Os dossiers mais complexos têm um calendário definido antecipadamente. Informamo-lo em cada etapa-chave do tratamento.\"},{\"question\":\"Posso marcar uma reunião?\",\"answer\":\"Absolutamente. Propomos reuniões em escritório em Genebra ou Lausana, bem como consultas por videoconferência. A primeira reunião é sem compromisso e permite-lhe expor a sua situação com serenidade. Contacte-nos através do formulário ou por telefone.\"},{\"question\":\"É confidencial?\",\"answer\":\"A confidencialidade é um princípio fundamental da nossa profissão. Todas as informações que nos confia são protegidas pelo segredo profissional e tratadas com a máxima discrição. Os seus dados nunca são partilhados com terceiros sem o seu consentimento explícito.\"}]}}]\n1e:[\"$\",\"$L29\",null,{\"bg\":\"stone\",\"slant\":\"left\",\"slantFill\":\"#F8F9FC\",\"t\":{\"overline\":\"Contacte-nos\",\"title\":\"Vamos falar do seu projeto\",\"subtitle\":\"Preencha o formulário abaixo e responderemos dentro de 24 horas úteis.\",\"trustLine\":\"Resposta em 24 horas úteis · Confidencialidade garantida\",\"fullName\":\"Nome completo *\",\"company\":\"Empresa\",\"email\":\"Endereço de e-mail *\",\"phone\":\"Telefone\",\"subject\":\"Assunto *\",\"subjectDefault\":\"Selecionar um assunto…\",\"message\":\"Mensagem *\",\"required\":\"* Campos obrigatórios\",\"submit\":\"Enviar mensagem\",\"submitting\":\"A enviar…\",\"successTitle\":\"Mensagem enviada!\",\"successMsg\":\"Obrigado pela sua mensagem. A nossa equipa entrará em contacto brevemente.\",\"sendAnother\":\"Enviar outra mensagem\",\"errorTitle\":\"Falha no envio\",\"errorMsg\":\"Ocorreu um erro. Tente novamente ou contacte-nos diretamente por telefone.\",\"retry\":\"Tentar novamente\",\"subjects\":{\"accounting\":\"Contabilidade & Fiscalidade\",\"consulting\":\"Consultoria de gestão\",\"audit\":\"Auditoria & Revisão\",\"patrimony\":\"Planeamento patrimonial\",\"creation\":\"Criação de empresa\",\"hr\":\"RH & Salários\",\"other\":\"Outro\"},\"errors\":{\"name\":\"O seu nome é obrigatório.\",\"email\":\"O seu endereço de e-mail é obrigatório.\",\"emailInvalid\":\"Endereço de e-mail inválido.\",\"subject\":\"O assunto é obrigatório.\",\"message\":\"A sua mensagem é obrigatória.\"},\"placeholders\":{\"name\":\"Sophie Dupont\",\"company\":\"A Minha Empresa Lda\",\"email\":\"sophie@exemplo.ch\",\"phone\":\"+41 79 000 00 00\",\"message\":\"Descreva brevemente a sua necessidade…\"}}}]\n1f:[\"$\",\"footer\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"h-[3px] bg-gold\",\"aria-hidden\":\"true\"}],[\"$\",\"div\",null,{\"className\":\"bg-navy\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container-main pt-14 pb-10 lg:pt-16 lg:pb-12\",\"children\":[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"md:col-span-2 lg:col-span-1 flex flex-col gap-5\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/pt\",\"className\":\"inline-flex self-start rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold\",\"aria-label\":\"SRD Partners Sàrl\",\"children\":[\"$\",\"div\",null,{\"className\":\"bg-white rounded-lg px-3 py-2\",\"children\":[\"$\",\"$L12\",null,{\"src\":\"/logo.png\",\"alt\":\"SRD Partners Sàrl\",\"width\":900,\"height\":600,\"className\":\"h-10 w-auto\"}]}]}],[\"$\",\"p\",null,{\"className\":\"font-body text-[0.8rem] text-white/45 leading-relaxed max-w-[220px]\",\"children\":\"Gabinete fiduciário independente · Romandia\"}],false]}],[\"$\",\"div\",null,{\"className\":\"flex flex-col gap-4\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-body text-[10px] tracking-[0.22em] uppercase font-semibold text-gold\",\"children\":\"Navegação\"}],[\"$\",\"ul\",null,{\"className\":\"flex flex-col gap-2.5\",\"children\":[[\"$\",\"li\",\"/pt\",{\"children\":[\"$\",\"$L13\",null,{\"href\":\"/pt\",\"className\":\"font-body text-sm text-white/50 hover:text-white transition-colors duration-200 focus-visible:outline-no